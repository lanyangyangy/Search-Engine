# ==========================================
# 1. 巨大的语料库和动态生成的数据文件
# ==========================================
# 过滤存放原始语料的文件夹
data/
yuliao*/
# 过滤可能生成的持久化索引文件或日志
*.dat
*.idx
*.log

# ==========================================
# 2. C++ 编译产生的二进制文件
# ==========================================
# 过滤你每次用 g++ 编译出来的可执行文件
test
*.o
*.out
*.exe
build/

# ==========================================
# 3. 崩溃产生的 Core Dump 文件
# ==========================================
# 之前段错误产生的那些庞大内存快照，绝不能传到 GitHub 上
core
core.*

# ==========================================
# 4. 系统或编辑器产生的临时文件
# ==========================================
.vscode/
.idea/
*.swp
.DS_Store